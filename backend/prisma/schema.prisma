generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PLACED
  ACCEPTED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  REJECTED
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String?
  googleId      String?        @unique
  name          String
  image         String?
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lastLoginAt   DateTime?
  termsVersion  String?
  termsAcceptedAt DateTime?
  
  orders        Order[]
  wishlists     Wishlist[]
  reviews       Review[]
  notifications Notification[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  products    Product[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                     String    @id @default(uuid())
  name                   String
  description            String    @db.Text
  price                  Float
  stock                  Int       @default(0)
  images                 Json      // Array of image URLs
  materials              String?
  personalizationOptions Json?     // Configurable options, e.g., ["name", "message", "image"]
  tags                   Json?     // Array of tags
  
  categoryId             String?
  category               Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  orderItems             OrderItem[]
  wishlists              Wishlist[]
  reviews                Review[]

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model Order {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber  String?
  totalAmount  Float
  status       OrderStatus   @default(PLACED)
  deliveryDate DateTime?
  rejectionReason String?
  orderItems   OrderItem[]
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model OrderItem {
  id                 String  @id @default(uuid())
  orderId            String
  order              Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId          String
  product            Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity           Int
  price              Float
  personalizationData Json?   // Storing actual user inputs for personalization
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Wishlist {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, productId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?  @db.Text
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("USER") // "USER" or "ADMIN"
  title     String   @default("Notification")
  message   String
  read      Boolean  @default(false)
  
  createdAt DateTime @default(now())
}
